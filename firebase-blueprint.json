{
  "entities": {
    "PortfolioItem": {
      "title": "Portfolio Item",
      "description": "A piece of work showcased in the studio portfolio",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "category": { "type": "string" },
        "imageUrl": { "type": "string" },
        "projectUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "category", "imageUrl", "createdAt"]
    },
    "Service": {
      "title": "Service Offered",
      "description": "A digital service offered by NEXOVA STUDIO",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "iconName": { "type": "string" },
        "order": { "type": "number" }
      },
      "required": ["title", "description", "iconName", "order"]
    },
    "Order": {
      "title": "Project Order",
      "description": "A project request submitted by a client",
      "type": "object",
      "properties": {
        "fullName": { "type": "string" },
        "email": { "type": "string" },
        "socialMedia": { "type": "string" },
        "serviceType": { "type": "string" },
        "projectTitle": { "type": "string" },
        "projectDetails": { "type": "string" },
        "budgetRange": { "type": "string" },
        "deadline": { "type": "string" },
        "referenceUrl": { "type": "string" },
        "preferredComm": { "type": "string" },
        "paymentProof": { "type": "string" },
        "paymentStatus": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["fullName", "email", "serviceType", "projectTitle", "projectDetails", "createdAt"]
    },
    "Feedback": {
      "title": "Client Feedback",
      "description": "User feedback or testimonials",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "rating", "comment", "createdAt"]
    }
  },
  "firestore": {
    "portfolio": {
      "schema": "PortfolioItem",
      "description": "List of portfolio items"
    },
    "services": {
      "schema": "Service",
      "description": "List of services offered"
    },
    "messages": {
      "schema": "Order",
      "description": "Project orders"
    },
    "feedback": {
      "schema": "Feedback",
      "description": "Client feedback"
    }
  }
}
